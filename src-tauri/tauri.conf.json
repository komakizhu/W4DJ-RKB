{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "W4DJ",
  "version": "0.1.0",
  "identifier": "com.slipstream.w4dj",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:1423",
    "frontendDist": "../app/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "W4DJ",
        "width": 880,
        "height": 620,
        "minWidth": 760,
        "minHeight": 540,
        "center": true,
        "visible": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ffmpeg"
    ]
  }
}
