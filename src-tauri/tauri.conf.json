{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "W4DJ",
  "version": "0.1.0",
  "identifier": "com.slipstream.w4dj",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "W4DJ",
        "width": 880,
        "height": 620,
        "minWidth": 760,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false,
        "transparent": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
