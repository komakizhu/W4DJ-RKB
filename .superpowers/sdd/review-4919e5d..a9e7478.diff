+use w4dj::config::{Config, LosslessFormat, Mode};
+use w4dj::gui::{launcher_available, GuiShell};
+use w4dj::task::TaskController;
+
+#[test]
+fn gui_module_exposes_launcher() {
+    assert!(launcher_available());
+}
+
+#[test]
+fn gui_shell_tracks_basic_user_choices() {
+    let config = Config {
+        source: String::from("/music/source"),
+        destination: String::from("/music/destination"),
+        mode: Mode::Lossless,
+        lossless_format: Some(LosslessFormat::Aiff),
+    };
+    let task = TaskController::running(4);
+    let shell = GuiShell::from_config(&config, &task);
+
+    assert_eq!(shell.source_directory, "/music/source");
+    assert_eq!(shell.destination_directory, "/music/destination");
+    assert!(matches!(shell.mode, Mode::Lossless));
+    assert!(matches!(shell.lossless_format, Some(LosslessFormat::Aiff)));
+    assert_eq!(shell.task.total, 4);
+    assert_eq!(shell.task.completed, 0);
+}
